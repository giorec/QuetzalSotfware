---
// Services.astro – QuetzalSoftware
const services = [
  {
    id: 'web-performance',
    title: 'Desarrollo Web de Alto Rendimiento',
    description:
      'Creamos aplicaciones web rápidas, seguras y escalables adaptadas a las necesidades de tu empresa. Desde portales corporativos hasta plataformas SaaS con arquitecturas modernas.',
    features: ['APIs RESTful & GraphQL', 'Optimización Core Web Vitals', 'PWA & SSR/SSG', 'Seguridad empresarial'],
    gradient: 'from-green-50 to-emerald-50',
    iconBg: 'bg-green-100',
    iconColor: 'text-green-700',
    accentLine: 'bg-green-600',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 7.5l3 2.25-3 2.25m4.5 0h3m-9 8.25h13.5A2.25 2.25 0 0021 18V6a2.25 2.25 0 00-2.25-2.25H5.25A2.25 2.25 0 003 6v12a2.25 2.25 0 002.25 2.25z"/>
    </svg>`,
  },
  {
    id: 'custom-systems',
    title: 'Sistemas y Plataformas a Medida',
    description:
      'Diseñamos e implementamos soluciones de software personalizadas que se ajustan perfectamente a tus procesos de negocio, eliminando fricciones y maximizando la productividad.',
    features: ['ERPs y CRMs personalizados', 'Dashboards analíticos', 'Gestión de procesos', 'Bases de datos robustas'],
    gradient: 'from-teal-50 to-green-50',
    iconBg: 'bg-teal-100',
    iconColor: 'text-teal-700',
    accentLine: 'bg-teal-600',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M11.42 15.17L17.25 21A2.652 2.652 0 0021 17.25l-5.877-5.877M11.42 15.17l2.496-3.03c.317-.384.74-.626 1.208-.766M11.42 15.17l-4.655 5.653a2.548 2.548 0 11-3.586-3.586l6.837-5.63m5.108-.233c.55-.164 1.163-.188 1.743-.14a4.5 4.5 0 004.486-6.336l-3.276 3.277a3.004 3.004 0 01-2.25-2.25l3.276-3.276a4.5 4.5 0 00-6.336 4.486c.091 1.076-.071 2.264-.904 2.95l-.102.085m-1.745 1.437L5.909 7.5H4.5L2.25 3.75l1.5-1.5L7.5 4.5v1.409l4.26 4.26m-1.745 1.437l1.745-1.437m6.615 8.206L15.75 15.75M4.867 19.125h.008v.008h-.008v-.008z"/>
    </svg>`,
  },
  {
    id: 'automation-integration',
    title: 'Automatización e Integración',
    description:
      'Conectamos y automatizamos tus sistemas para eliminar tareas repetitivas, reducir errores y liberar el tiempo de tu equipo para lo que realmente importa: hacer crecer tu empresa.',
    features: ['Integración de APIs terceros', 'Flujos de trabajo automáticos', 'Webhooks & Event-driven', 'Docker & CI/CD'],
    gradient: 'from-emerald-50 to-cyan-50',
    iconBg: 'bg-emerald-100',
    iconColor: 'text-emerald-700',
    accentLine: 'bg-emerald-600',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12a7.5 7.5 0 0015 0m-15 0a7.5 7.5 0 1115 0m-15 0H3m16.5 0H21m-1.5 0H12m-8.457 3.077l1.41-.513m14.095-5.13l1.41-.513M5.106 17.785l1.15-.964m11.49-9.642l1.149-.964M7.501 19.795l.75-1.3m7.5-12.99l.75-1.3m-6.063 16.658l.26-1.477m2.605-14.772l.26-1.477m0 17.726l-.26-1.477M10.698 4.614l-.26-1.477M16.5 19.794l-.75-1.299M7.5 4.205L12 12m6.894 5.785l-1.149-.964M6.256 7.178l-1.15-.964m15.352 8.864l-1.41-.513M4.954 9.435l-1.41-.514M12.002 12l-3.75 6.495"/>
    </svg>`,
  },
];
---

<section id="servicios" class="py-24 bg-white relative overflow-hidden">
  <!-- Subtle top decorative line -->
  <div aria-hidden="true" class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-16 bg-gradient-to-b from-transparent via-green-300 to-transparent"></div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block text-green-700 text-sm font-semibold uppercase tracking-widest mb-3">
        ¿Qué hacemos?
      </span>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
        Nuestros Servicios
      </h2>
      <p class="max-w-2xl mx-auto text-gray-500 text-lg">
        Soluciones tecnológicas diseñadas para resolver los retos reales de tu empresa con eficiencia y precisión.
      </p>
    </div>

    <!-- Service cards grid -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {services.map((service) => (
        <article
          id={`service-${service.id}`}
          class={`group relative flex flex-col bg-gradient-to-br ${service.gradient} border border-gray-100 rounded-2xl p-8 transition-all duration-300 hover:-translate-y-2 hover:shadow-2xl hover:shadow-green-100 cursor-default`}
        >
          <!-- Accent top line -->
          <div class={`absolute top-0 left-8 right-8 h-0.5 ${service.accentLine} rounded-full opacity-0 group-hover:opacity-100 transition-opacity duration-300`}></div>

          <!-- Icon -->
          <div class={`inline-flex items-center justify-center w-14 h-14 ${service.iconBg} ${service.iconColor} rounded-xl mb-6 transition-transform duration-300 group-hover:scale-110`}>
            <div class="w-7 h-7" set:html={service.icon} />
          </div>

          <!-- Title -->
          <h3 class="text-xl font-bold text-gray-900 mb-3 leading-snug">
            {service.title}
          </h3>

          <!-- Description -->
          <p class="text-gray-500 text-sm leading-relaxed mb-6 flex-grow">
            {service.description}
          </p>

          <!-- Features list -->
          <ul class="space-y-2">
            {service.features.map((feat) => (
              <li class="flex items-center gap-2 text-sm text-gray-600">
                <svg class={`w-4 h-4 flex-shrink-0 ${service.iconColor}`} fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {feat}
              </li>
            ))}
          </ul>

          <!-- Bottom CTA -->
          <a
            href="#contacto"
            class={`mt-8 inline-flex items-center gap-1.5 text-sm font-semibold ${service.iconColor} hover:gap-3 transition-all duration-200`}
            aria-label={`Consultar sobre ${service.title}`}
          >
            Consultar servicio
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </article>
      ))}
    </div>
  </div>
</section>
