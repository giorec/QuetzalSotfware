---
// Contact.astro – QuetzalSoftware (Web3Forms integration)
// Replace YOUR_WEB3FORMS_ACCESS_KEY with the key from https://web3forms.com
const WEB3FORMS_KEY = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? 'YOUR_WEB3FORMS_ACCESS_KEY';
---

<section id="contacto" class="py-24 bg-white relative overflow-hidden">
  <!-- Background decorations -->
  <div aria-hidden="true" class="absolute inset-0 pointer-events-none">
    <div class="absolute top-0 left-1/2 -translate-x-1/2 w-px h-16 bg-gradient-to-b from-transparent via-green-300 to-transparent"></div>
    <div class="absolute -bottom-40 -right-40 w-96 h-96 rounded-full bg-green-50 blur-3xl opacity-70"></div>
    <div class="absolute -top-20 -left-20 w-72 h-72 rounded-full bg-green-50 blur-3xl opacity-50"></div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="text-center mb-16">
      <span class="inline-block text-green-700 text-sm font-semibold uppercase tracking-widest mb-3">
        ¿Tienes un proyecto?
      </span>
      <h2 class="text-4xl sm:text-5xl font-extrabold text-gray-900 leading-tight mb-4">
        Hablemos
      </h2>
      <p class="max-w-xl mx-auto text-gray-500 text-lg">
        Cuéntanos sobre tu proyecto y encontremos juntos la mejor solución tecnológica para tu empresa.
      </p>
    </div>

    <!-- Two-column: Form + Contact info -->
    <div class="grid grid-cols-1 lg:grid-cols-5 gap-12 items-start">

      <!-- Contact form (3 columns wide) -->
      <div class="lg:col-span-3 bg-white rounded-3xl border border-gray-100 shadow-xl shadow-gray-100 p-8 sm:p-10">

        <!-- Success state (hidden by default) -->
        <div
          id="form-success"
          class="hidden flex-col items-center justify-center text-center py-12 gap-4"
          role="status"
          aria-live="polite"
        >
          <div class="w-20 h-20 rounded-full bg-green-100 flex items-center justify-center mb-2 animate-bounce-once">
            <svg class="w-10 h-10 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900">¡Mensaje enviado!</h3>
          <p class="text-gray-500 max-w-xs">
            Gracias por contactarnos. Te responderemos en menos de <strong class="text-gray-700">24 horas</strong>.
          </p>
          <button
            id="form-reset-btn"
            class="mt-4 text-sm font-semibold text-green-700 hover:text-green-800 underline underline-offset-2 transition-colors duration-200"
          >
            Enviar otro mensaje
          </button>
        </div>

        <!-- Error banner (hidden by default) -->
        <div
          id="form-error"
          class="hidden items-center gap-3 bg-red-50 border border-red-200 text-red-700 text-sm font-medium px-4 py-3 rounded-xl mb-6"
          role="alert"
          aria-live="assertive"
        >
          <svg class="w-5 h-5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
          </svg>
          <span id="form-error-text">Hubo un error. Por favor intenta de nuevo.</span>
        </div>

        <!-- The form -->
        <form id="contact-form" novalidate class="space-y-5">
          <!-- Web3Forms hidden fields -->
          <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
          <input type="hidden" name="subject" value="Nuevo contacto desde QuetzalSoftware.com" />
          <input type="hidden" name="from_name" value="QuetzalSoftware Web" />
          <!-- Honeypot anti-spam -->
          <input type="checkbox" name="botcheck" class="hidden" aria-hidden="true" />

          <h3 class="text-xl font-bold text-gray-900 mb-6">Envíanos un mensaje</h3>

          <!-- Name -->
          <div>
            <label for="contact-name" class="block text-sm font-semibold text-gray-700 mb-1.5">
              Nombre completo <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <input
              type="text"
              id="contact-name"
              name="name"
              required
              minlength="2"
              autocomplete="name"
              placeholder="Tu nombre completo"
              class="peer w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-400 text-sm bg-gray-50 focus:bg-white focus:border-green-500 focus:ring-2 focus:ring-green-100 outline-none transition-all duration-200 invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-400"
            />
            <p class="hidden peer-[&:not(:placeholder-shown):not(:focus):invalid]:block text-xs text-red-500 mt-1.5 pl-1">
              Por favor ingresa tu nombre.
            </p>
          </div>

          <!-- Email -->
          <div>
            <label for="contact-email" class="block text-sm font-semibold text-gray-700 mb-1.5">
              Correo electrónico <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <input
              type="email"
              id="contact-email"
              name="email"
              required
              autocomplete="email"
              placeholder="correo@tuempresa.com"
              class="peer w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-400 text-sm bg-gray-50 focus:bg-white focus:border-green-500 focus:ring-2 focus:ring-green-100 outline-none transition-all duration-200 invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-400"
            />
            <p class="hidden peer-[&:not(:placeholder-shown):not(:focus):invalid]:block text-xs text-red-500 mt-1.5 pl-1">
              Por favor ingresa un correo válido.
            </p>
          </div>

          <!-- Phone (optional) -->
          <div>
            <label for="contact-phone" class="block text-sm font-semibold text-gray-700 mb-1.5">
              Teléfono <span class="text-gray-400 font-normal">(opcional)</span>
            </label>
            <input
              type="tel"
              id="contact-phone"
              name="phone"
              autocomplete="tel"
              placeholder="+502 0000-0000"
              class="w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-400 text-sm bg-gray-50 focus:bg-white focus:border-green-500 focus:ring-2 focus:ring-green-100 outline-none transition-all duration-200"
            />
          </div>

          <!-- Service selector -->
          <div>
            <label for="contact-service" class="block text-sm font-semibold text-gray-700 mb-1.5">
              ¿En qué podemos ayudarte? <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <div class="relative">
              <select
                id="contact-service"
                name="service"
                required
                class="w-full px-4 py-3 pr-10 rounded-xl border border-gray-200 text-gray-700 text-sm bg-gray-50 focus:bg-white focus:border-green-500 focus:ring-2 focus:ring-green-100 outline-none transition-all duration-200 appearance-none cursor-pointer"
              >
                <option value="" disabled selected>Selecciona un servicio...</option>
                <option value="Desarrollo Web de Alto Rendimiento">🌐 Desarrollo Web de Alto Rendimiento</option>
                <option value="Sistemas y Plataformas a Medida">⚙️ Sistemas y Plataformas a Medida</option>
                <option value="Automatización e Integración">🔗 Automatización e Integración</option>
                <option value="Consultoría Técnica">💡 Consultoría Técnica</option>
                <option value="Otro">📋 Otro / No estoy seguro</option>
              </select>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </div>

          <!-- Budget range -->
          <div>
            <label for="contact-budget" class="block text-sm font-semibold text-gray-700 mb-1.5">
              Presupuesto aproximado <span class="text-gray-400 font-normal">(opcional)</span>
            </label>
            <div class="relative">
              <select
                id="contact-budget"
                name="budget"
                class="w-full px-4 py-3 pr-10 rounded-xl border border-gray-200 text-gray-700 text-sm bg-gray-50 focus:bg-white focus:border-green-500 focus:ring-2 focus:ring-green-100 outline-none transition-all duration-200 appearance-none cursor-pointer"
              >
                <option value="" selected>Prefiero no indicarlo</option>
                <option value="Menos de $500">Menos de $500</option>
                <option value="$500 – $2,000">$500 – $2,000</option>
                <option value="$2,000 – $5,000">$2,000 – $5,000</option>
                <option value="$5,000 – $10,000">$5,000 – $10,000</option>
                <option value="Más de $10,000">Más de $10,000</option>
              </select>
              <svg class="absolute right-3 top-1/2 -translate-y-1/2 w-4 h-4 text-gray-400 pointer-events-none" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
              </svg>
            </div>
          </div>

          <!-- Message -->
          <div>
            <label for="contact-message" class="block text-sm font-semibold text-gray-700 mb-1.5">
              Cuéntanos tu idea <span class="text-red-500" aria-hidden="true">*</span>
            </label>
            <textarea
              id="contact-message"
              name="message"
              required
              minlength="10"
              rows="4"
              placeholder="Describe brevemente tu proyecto o necesidad... ¿Qué problema quieres resolver?"
              class="peer w-full px-4 py-3 rounded-xl border border-gray-200 text-gray-800 placeholder-gray-400 text-sm bg-gray-50 focus:bg-white focus:border-green-500 focus:ring-2 focus:ring-green-100 outline-none transition-all duration-200 resize-none invalid:[&:not(:placeholder-shown):not(:focus)]:border-red-400"
            ></textarea>
            <p class="hidden peer-[&:not(:placeholder-shown):not(:focus):invalid]:block text-xs text-red-500 mt-1.5 pl-1">
              Por favor describe tu proyecto (mínimo 10 caracteres).
            </p>
          </div>

          <!-- hCaptcha widget (Web3Forms) -->
          <div
            class="h-captcha"
            data-captcha="true"
            data-callback="onCaptchaSuccess"
            data-expired-callback="onCaptchaExpired"
          ></div>
          <!-- Captcha hint -->
          <p id="captcha-hint" class="text-xs text-amber-600 flex items-center gap-1.5 -mt-1">
            <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
              <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
            </svg>
            Completa el captcha para habilitar el envío.
          </p>

          <!-- Submit button -->
          <button
            type="submit"
            id="contact-submit"
            disabled
            class="w-full flex items-center justify-center gap-2 bg-green-700 hover:bg-green-800 active:bg-green-900 text-white font-bold text-base px-8 py-4 rounded-xl shadow-lg shadow-green-200 hover:shadow-green-300 transition-all duration-300 hover:-translate-y-0.5 focus:outline-none focus:ring-4 focus:ring-green-200 disabled:opacity-50 disabled:cursor-not-allowed disabled:translate-y-0 disabled:shadow-none disabled:bg-gray-400"
          >
            <!-- Default state -->
            <span id="btn-default" class="flex items-center gap-2">
              Enviar mensaje
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
              </svg>
            </span>
            <!-- Loading state -->
            <span id="btn-loading" class="hidden items-center gap-2">
              <svg class="w-5 h-5 animate-spin" fill="none" viewBox="0 0 24 24" aria-hidden="true">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"/>
              </svg>
              Enviando...
            </span>
          </button>

          <p class="text-xs text-gray-400 text-center">
            Al enviar aceptas que nos pongamos en contacto contigo para discutir tu proyecto.
          </p>
        </form>
      </div>

      <!-- Contact info (2 columns wide) -->
      <div class="lg:col-span-2 space-y-6">

        <!-- Why us card -->
        <div class="bg-green-700 text-white rounded-3xl p-7 shadow-xl shadow-green-200">
          <h3 class="text-lg font-bold mb-4">¿Por qué elegirnos?</h3>
          <ul class="space-y-3">
            {[
              'Respuesta en menos de 24 horas',
              'Presupuesto sin compromisos',
              'Consultoría técnica inicial gratuita',
              'Desarrollo ágil con reportes semanales',
              'Código fuente 100% tuyo al finalizar',
            ].map((item) => (
              <li class="flex items-start gap-3 text-sm text-green-100">
                <svg class="w-4 h-4 text-green-300 flex-shrink-0 mt-0.5" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
                {item}
              </li>
            ))}
          </ul>
        </div>

        <!-- Direct contact -->
        <div class="bg-gray-50 border border-gray-100 rounded-3xl p-7 space-y-4">
          <h3 class="text-lg font-bold text-gray-900">¿Prefieres contacto directo?</h3>

          <!-- WhatsApp -->
          <a
            href="https://wa.me/50242521896?text=Hola%20Giovanni%2C%20vi%20tu%20sitio%20web%20y%20me%20gustar%C3%ADa%20hablar%20sobre%20mi%20proyecto."
            id="contact-whatsapp"
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-4 p-4 rounded-xl bg-white border border-gray-100 shadow-sm hover:border-green-300 hover:shadow-green-100 hover:shadow-md transition-all duration-300 group"
            aria-label="Enviar WhatsApp a +502 4252-1896"
          >
            <div class="w-11 h-11 rounded-xl bg-green-100 flex items-center justify-center flex-shrink-0 group-hover:bg-green-600 transition-colors duration-300">
              <svg class="w-5 h-5 text-green-700 group-hover:text-white transition-colors duration-300" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
            </div>
            <div>
              <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">WhatsApp</p>
              <p class="text-sm font-bold text-gray-900 mt-0.5">+502 4252-1896</p>
              <p class="text-xs text-green-600 mt-0.5">Mensaje directo →</p>
            </div>
          </a>

          <!-- Email -->
          <a
            href="mailto:ronalrecinoscortez@gmail.com"
            id="contact-email-link"
            class="flex items-center gap-4 p-4 rounded-xl bg-white border border-gray-100 shadow-sm hover:border-green-300 hover:shadow-green-100 hover:shadow-md transition-all duration-300 group"
            aria-label="Enviar correo a ronalrecinoscortez@gmail.com"
          >
            <div class="w-11 h-11 rounded-xl bg-green-100 flex items-center justify-center flex-shrink-0 group-hover:bg-green-600 transition-colors duration-300">
              <svg class="w-5 h-5 text-green-700 group-hover:text-white transition-colors duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
            </div>
            <div class="overflow-hidden">
              <p class="text-xs text-gray-400 font-medium uppercase tracking-wide">Correo electrónico</p>
              <p class="text-sm font-bold text-gray-900 mt-0.5 truncate">ronalrecinoscortez@gmail.com</p>
            </div>
          </a>
        </div>

      </div>
    </div>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submitBtn = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const btnDefault = document.getElementById('btn-default');
  const btnLoading = document.getElementById('btn-loading');
  const successDiv = document.getElementById('form-success');
  const errorDiv = document.getElementById('form-error');
  const errorText = document.getElementById('form-error-text');
  const resetBtn = document.getElementById('form-reset-btn');

  function setLoading(loading: boolean) {
    if (!submitBtn || !btnDefault || !btnLoading) return;
    submitBtn.disabled = loading;
    btnDefault.classList.toggle('hidden', loading);
    btnDefault.classList.toggle('flex', !loading);
    btnLoading.classList.toggle('hidden', !loading);
    btnLoading.classList.toggle('flex', loading);
  }

  function showError(msg: string) {
    if (!errorDiv || !errorText) return;
    errorText.textContent = msg;
    errorDiv.classList.remove('hidden');
    errorDiv.classList.add('flex');
    errorDiv.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  function hideError() {
    errorDiv?.classList.add('hidden');
    errorDiv?.classList.remove('flex');
  }

  function showSuccess() {
    form?.classList.add('hidden');
    successDiv?.classList.remove('hidden');
    successDiv?.classList.add('flex');
    successDiv?.scrollIntoView({ behavior: 'smooth', block: 'center' });
  }

  // hCaptcha callbacks — must be global functions
  (window as any).onCaptchaSuccess = () => {
    if (!submitBtn) return;
    submitBtn.disabled = false;
    const hint = document.getElementById('captcha-hint');
    if (hint) {
      hint.classList.remove('text-amber-600');
      hint.classList.add('text-green-600');
      hint.innerHTML = `
        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
        </svg>
        Captcha completado. ¡Ya puedes enviar tu mensaje!`;
    }
  };

  (window as any).onCaptchaExpired = () => {
    if (!submitBtn) return;
    submitBtn.disabled = true;
    const hint = document.getElementById('captcha-hint');
    if (hint) {
      hint.classList.remove('text-green-600');
      hint.classList.add('text-amber-600');
      hint.innerHTML = `
        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        El captcha expiró. Por favor compruébalo de nuevo.`;
    }
  };

  resetBtn?.addEventListener('click', () => {
    form?.reset();
    form?.classList.remove('hidden');
    successDiv?.classList.add('hidden');
    successDiv?.classList.remove('flex');
    hideError();
    setLoading(false);
    // Disable button and reset hint again
    if (submitBtn) submitBtn.disabled = true;
    const hint = document.getElementById('captcha-hint');
    if (hint) {
      hint.classList.remove('text-green-600');
      hint.classList.add('text-amber-600');
      hint.innerHTML = `
        <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20" aria-hidden="true">
          <path fill-rule="evenodd" d="M8.257 3.099c.765-1.36 2.722-1.36 3.486 0l5.58 9.92c.75 1.334-.213 2.98-1.742 2.98H4.42c-1.53 0-2.493-1.646-1.743-2.98l5.58-9.92zM11 13a1 1 0 11-2 0 1 1 0 012 0zm-1-8a1 1 0 00-1 1v3a1 1 0 002 0V6a1 1 0 00-1-1z" clip-rule="evenodd"/>
        </svg>
        Completa el captcha para habilitar el envío.`;
    }
    // Reset hCaptcha widget if available
    if (typeof (window as any).hcaptcha !== 'undefined') {
      (window as any).hcaptcha.reset();
    }
  });

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    hideError();

    if (!form.checkValidity()) {
      form.reportValidity();
      return;
    }

    setLoading(true);

    try {
      const data = new FormData(form);
      const res = await fetch('https://api.web3forms.com/submit', {
        method: 'POST',
        body: data,
      });

      const json = await res.json();

      if (res.ok && json.success) {
        showSuccess();
      } else {
        showError(json.message ?? 'Ocurrió un error al enviar. Por favor intenta de nuevo.');
        setLoading(false);
      }
    } catch {
      showError('Error de conexión. Revisa tu internet e intenta de nuevo.');
      setLoading(false);
    }
