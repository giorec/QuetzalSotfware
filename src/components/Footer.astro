---
// Footer.astro – QuetzalSoftware
const currentYear = new Date().getFullYear();

const links = [
  { label: 'Servicios', href: '#servicios' },
  { label: 'Nosotros', href: '#nosotros' },
  { label: 'Contacto', href: '#contacto' },
];

const socials = [
  {
    name: 'WhatsApp',
    href: 'https://wa.me/50242521896',
    icon: `<svg fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>`,
  },
  {
    name: 'Email',
    href: 'mailto:ronalrecinoscortez@gmail.com',
    icon: `<svg fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
  },
];
---

<footer class="bg-gray-900 text-white" role="contentinfo">
  <!-- Top divider wave -->
  <div aria-hidden="true" class="w-full overflow-hidden leading-none bg-white">
    <svg class="w-full h-12 fill-gray-900" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1440 48" preserveAspectRatio="none">
      <path d="M0,48L60,42.7C120,37,240,27,360,24C480,21,600,27,720,32C840,37,960,43,1080,42.7C1200,43,1320,37,1380,34.7L1440,32L1440,48L1380,48C1320,48,1200,48,1080,48C960,48,840,48,720,48C600,48,480,48,360,48C240,48,120,48,60,48L0,48Z"/>
    </svg>
  </div>

  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Main footer content -->
    <div class="py-14 grid grid-cols-1 sm:grid-cols-3 gap-10 items-start">

      <!-- Brand column -->
      <div class="sm:col-span-1 space-y-4">
        <a href="#inicio" class="inline-flex items-center group" aria-label="QuetzalSoftware inicio">
          <img
            src="/logo.png"
            alt="QuetzalSoftware logo"
            class="h-10 w-auto object-contain brightness-0 invert opacity-90 group-hover:opacity-100 transition-opacity duration-300"
            width="160"
            height="40"
          />
        </a>
        <p class="text-gray-400 text-sm leading-relaxed max-w-xs">
          Soluciones de software empresarial hechas con precisión y propósito.<br/>
          <em class="text-green-400 not-italic font-medium">Estabilidad &amp; Crecimiento.</em>
        </p>
        <!-- Social icons -->
        <div class="flex items-center gap-3 pt-1">
          {socials.map((s) => (
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={s.name}
              class="w-9 h-9 rounded-lg bg-gray-800 hover:bg-green-600 flex items-center justify-center text-gray-400 hover:text-white transition-all duration-300"
            >
              <span class="w-4 h-4" set:html={s.icon} />
            </a>
          ))}
        </div>
      </div>

      <!-- Navigation links -->
      <nav class="space-y-3" aria-label="Footer navigation">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">Navegación</p>
        <ul class="space-y-2">
          {links.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-gray-400 hover:text-green-400 transition-colors duration-200 flex items-center gap-1.5 group"
              >
                <span class="w-1.5 h-1.5 rounded-full bg-gray-700 group-hover:bg-green-500 transition-colors duration-200"></span>
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Contact info -->
      <div class="space-y-3">
        <p class="text-xs font-semibold text-gray-500 uppercase tracking-widest mb-4">Contacto</p>
        <a
          href="https://wa.me/50242521896"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-2 text-sm text-gray-400 hover:text-green-400 transition-colors duration-200"
          aria-label="WhatsApp +502 4252-1896"
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
          </svg>
          +502 4252-1896
        </a>
        <a
          href="mailto:ronalrecinoscortez@gmail.com"
          class="flex items-center gap-2 text-sm text-gray-400 hover:text-green-400 transition-colors duration-200 break-all"
          aria-label="Email ronalrecinoscortez@gmail.com"
        >
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
          ronalrecinoscortez@gmail.com
        </a>
        <p class="flex items-center gap-2 text-sm text-gray-500">
          <svg class="w-4 h-4 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
          Guatemala
        </p>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="border-t border-gray-800 py-6 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-gray-600">
      <p>© {currentYear} <strong class="text-gray-500">QuetzalSoftware</strong>. Todos los derechos reservados.</p>
      <p class="text-green-700 font-medium tracking-wide">Estabilidad &amp; Crecimiento</p>
    </div>
  </div>
</footer>
