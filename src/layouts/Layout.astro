---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'QuetzalSoftware – Estabilidad & Crecimiento',
  description = 'Empresa de desarrollo de software especializada en soluciones web de alto rendimiento, sistemas a medida y automatización empresarial.',
} = Astro.props;
---

<!doctype html>
<html lang="es" class="scroll-smooth">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap"
      rel="stylesheet"
    />
  </head>
  <body class="bg-white text-gray-800 font-[Inter,sans-serif] antialiased">
    <slot />
  </body>
</html>
